# OpenAI (Task 10 - Generation)
OPENAI_API_KEY=sk-xxx

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=jina_xxx

# PageIndex (Task 8 - Vectorless RAG)
PAGEINDEX_API_KEY=pi_xxx

# Weaviate Cloud (Task 4, optional - can use local Docker instead)
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx

# Embedding model (if using API-based)
# COHERE_API_KEY=xxx

# ── API config (api/config.py) ──────────────────────────────────────────────

# CORS - domain web UI được phép gọi API (vd. https://oggishi.github.io)
ALLOWED_ORIGINS=*

# Bật auth cho /chat: nếu set, client phải gửi header "X-API-Key: <giá trị>".
# Để trống = /chat mở công khai (mặc định, giữ demo hoạt động không cần đổi frontend).
API_KEY=

# Rate limit cho /chat (cú pháp slowapi, vd "20/minute", "100/hour")
RATE_LIMIT=20/minute

# Cost guard - ngân sách USD/ngày cho OpenAI API, /chat trả 429 khi vượt
DAILY_COST_LIMIT_USD=5
PRICE_INPUT_PER_1M_USD=0.15
PRICE_OUTPUT_PER_1M_USD=0.60

# Redis - lưu trạng thái rate limit + cost guard chia sẻ giữa các worker
# (docker-compose tự set tới service "redis"; để trống = in-memory)
REDIS_URL=

# Logging
LOG_LEVEL=INFO
